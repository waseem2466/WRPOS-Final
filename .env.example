# WR POS Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Google Gemini AI Configuration  
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek AI Configuration (Optional)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq AI Configuration (Optional)
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_MODEL=llama3-70b-8192

# Zhipu AI Configuration (Optional)
VITE_ZHIPU_AI_API_KEY=your_zhipu_api_key_here
VITE_ZHIPU_MODEL=glm-4-flash

# Local Ollama Configuration (Desktop app / WhatsApp bot)
OLLAMA_BASE_URL=http://127.0.0.1:11434
VITE_LOCAL_OLLAMA_MODEL=phi3:latest
LOCAL_OLLAMA_MODEL=phi3:latest
LOCAL_OLLAMA_TIMEOUT_MS=300000
LOCAL_OLLAMA_NUM_CTX=1024
LOCAL_OLLAMA_NUM_PREDICT=80

# Ollama Cloud API Configuration (Optional)
VITE_OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
VITE_OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud

# WhatsApp Cloud API Configuration
WHATSAPP_TOKEN=your_whatsapp_cloud_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook Configuration
WEBHOOK_VERIFY_TOKEN=change_this_webhook_verify_token

# Application Configuration
NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=change_this_jwt_secret
