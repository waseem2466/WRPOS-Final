{
  "name": "wr-pos",
  "private": true,
  "version": "4.3.9",
  "description": "WR POS - Cloud-based Billing & Management",
  "author": "WR POS Enterprise",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit --pretty false",
    "validate": "npm run typecheck && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently --raw --shell powershell \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dist": "vite build && electron-builder --win",
    "deploy": "firebase deploy --only hosting",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.5",
    "@better-fetch/fetch": "^1.1.21",
    "@daveyplate/better-auth-tanstack": "^1.3.6",
    "@google/generative-ai": "^0.21.0",
    "@hookform/resolvers": "5.2.2",
    "@neondatabase/serverless": "^0.9.0",
    "@prisma/adapter-neon": "^5.10.2",
    "@prisma/client": "^7.2.0",
    "@tanstack/react-query": "^5.99.1",
    "@whiskeysockets/baileys": "^6.7.21",
    "bcryptjs": "^2.4.3",
    "buffer": "^6.0.3",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "firebase": "^10.8.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^1.8.0",
    "node-fetch": "^2.7.0",
    "openai": "^4.104.0",
    "pg": "^8.11.3",
    "picomatch": "^4.0.4",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.55.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.12.0",
    "sql.js": "^1.14.1",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pg": "^8.11.2",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "firebase-tools": "^13.35.1",
    "postcss": "^8.5.6",
    "prisma": "^7.2.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sql.js/**/*"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "compression": "normal",
    "npmArgs": [
      "--silent"
    ],
    "appId": "com.wrpos.app",
    "productName": "WR POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icons/Icon.ico",
      "node_modules/sql.js/**/*",
      "*.cjs",
      "*.mjs"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "build/icons/Icon.ico",
        "to": "Icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/Icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WR POS"
    }
  }
}
